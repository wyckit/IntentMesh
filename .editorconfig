# Pins formatting so `dotnet format --verify-no-changes` is deterministic across platforms.
# Without this, dotnet format defaults to CRLF on Windows while .gitattributes enforces LF — the
# gate then passes on CI (Linux) but fails for a Windows dev running the same command. LF here
# matches .gitattributes (`* text=auto eol=lf`, with .ps1 as crlf).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{csproj,props,targets,json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.ps1]
end_of_line = crlf

[*.tlmz]
charset = unset
trim_trailing_whitespace = false
insert_final_newline = false
