  "Concepts": [
    {
      "Id": "policy-root",
      "Label": "policy gate",
      "Category": "PolicyEngine",
      "Description": "Decides allow / warn / confirm / review / block for each intent node before execution. Authority lives here, not in language. Fail-closed: an unrecognized or zero-trust side-effecting node is blocked.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "risk-low",
      "Label": "low risk",
      "Category": "RiskClass",
      "Description": "Reads and pure analysis.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "risk-medium",
      "Label": "medium risk",
      "Category": "RiskClass",
      "Description": "Local writes / drafts (reversible, no external effect).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "risk-high",
      "Label": "high risk",
      "Category": "RiskClass",
      "Description": "External communication or destructive deletion.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "risk-critical",
      "Label": "critical risk",
      "Category": "RiskClass",
      "Description": "Irreversible system / financial / legal operations (out of scope for v0.1).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "dec-allow",
      "Label": "allow",
      "Category": "Decision",
      "Description": "Permit immediately.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "dec-warn",
      "Label": "allow with warning",
      "Category": "Decision",
      "Description": "Permit but surface a caution.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "dec-confirm",
      "Label": "require confirmation",
      "Category": "Decision",
      "Description": "Stage; execute only after explicit user confirmation.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "dec-review",
      "Label": "require review",
      "Category": "Decision",
      "Description": "Hold for human review.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "dec-block",
      "Label": "block",
      "Category": "Decision",
      "Description": "Refuse. The action never executes.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-zero-trust-side-effect",
      "Label": "pol-zero-trust-side-effect",
      "Category": "PolicyRule",
      "Description": "a node\u0027s TrustSource is retrieved-content or tool-output (Authority=none) AND it requests any side effect -\u003E block \u2014 retrieved content is data, not authority; it may not command tools",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-recipient-substitution",
      "Label": "pol-recipient-substitution",
      "Category": "PolicyRule",
      "Description": "an email recipient differs from the user-named recipient and was introduced by document content -\u003E block \u2014 recipient substitution from untrusted content",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-private-exfiltration",
      "Label": "pol-private-exfiltration",
      "Category": "PolicyRule",
      "Description": "private/sensitive content would be sent to an external or unknown recipient -\u003E block \u2014 would exfiltrate private data",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-command-not-allowlisted",
      "Label": "pol-command-not-allowlisted",
      "Category": "PolicyRule",
      "Description": "a command is not on the repository allow-list -\u003E block \u2014 shell is blocked by default; only allow-listed commands may run",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-secret-exposure",
      "Label": "pol-secret-exposure",
      "Category": "PolicyRule",
      "Description": "a code edit or pull-request body contains a repository secret value -\u003E block \u2014 would expose a secret",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-command-allowlisted",
      "Label": "pol-command-allowlisted",
      "Category": "PolicyRule",
      "Description": "a command is on the repository allow-list -\u003E require confirmation before running",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-query-untrusted",
      "Label": "pol-query-untrusted",
      "Category": "PolicyRule",
      "Description": "a query plan originates from untrusted retrieved content -\u003E block \u2014 untrusted content may not originate a database query",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-query-readonly",
      "Label": "pol-query-readonly",
      "Category": "PolicyRule",
      "Description": "a query plan mutates data (delete/drop/truncate/update) while the database role is read-only -\u003E block \u2014 the database role is read-only",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-query-table-missing",
      "Label": "pol-query-table-missing",
      "Category": "PolicyRule",
      "Description": "a query plan references a table that does not exist -\u003E block \u2014 unknown table",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-query-unbounded",
      "Label": "pol-query-unbounded",
      "Category": "PolicyRule",
      "Description": "a query plan has no row limit or exceeds the configured row cap -\u003E block \u2014 unbounded scan or over the row cap",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-delete-files",
      "Label": "pol-delete-files",
      "Category": "PolicyRule",
      "Description": "the action deletes files -\u003E require explicit per-file approval; never delete automatically",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-send-email",
      "Label": "pol-send-email",
      "Category": "PolicyRule",
      "Description": "the action transmits an email (external communication) -\u003E require confirmation before sending",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-local-write",
      "Label": "pol-local-write",
      "Category": "PolicyRule",
      "Description": "the action stages a local write (e.g. a tentative calendar block) -\u003E require confirmation before committing",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-draft-allowed",
      "Label": "pol-draft-allowed",
      "Category": "PolicyRule",
      "Description": "the action drafts an email to a recipient the user named -\u003E allow as a draft (send remains gated)",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-read-allowed",
      "Label": "pol-read-allowed",
      "Category": "PolicyRule",
      "Description": "the action is a low-risk read or pure analysis with no side effect -\u003E allow",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-unregistered",
      "Label": "pol-unregistered",
      "Category": "PolicyRule",
      "Description": "the action kind is not present in im-action-contracts -\u003E block \u2014 no typed contract exists for this action (fail-closed)",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pol-capability-not-granted",
      "Label": "pol-capability-not-granted",
      "Category": "PolicyRule",
      "Description": "the action\u0027s tool requires a capability the runtime has not been granted -\u003E block \u2014 capability scoping (the real-adapter framework gate)",
      "Aliases": [],
      "Properties": {}
    }
  ],
