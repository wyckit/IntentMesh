  "Concepts": [
    {
      "Id": "tools-root",
      "Label": "tool adapters",
      "Category": "AdapterRegistry",
      "Description": "Deterministic, sandboxed adapters. Each accepts ONLY a typed action contract, never raw language, and reports postconditions after executing against the fake workspace. No real side effects in v0.1.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "tool-calendar",
      "Label": "calendar adapter",
      "Category": "ToolAdapter",
      "Description": "Fake calendar: read events, classify fixed/flexible, stage tentative blocks.",
      "Aliases": [],
      "Properties": {
        "Consumes": "act-read-calendar,act-classify-events,act-create-calendar-block",
        "SideEffect": "local-write",
        "Capability": "calendar"
      }
    },
    {
      "Id": "tool-notes",
      "Label": "notes adapter",
      "Category": "ToolAdapter",
      "Description": "Fake notes/docs: locate and summarize. Reads untrusted content as DATA.",
      "Aliases": [],
      "Properties": {
        "Consumes": "act-find-notes,act-summarize-document",
        "SideEffect": "none",
        "Capability": "notes"
      }
    },
    {
      "Id": "tool-email",
      "Label": "email adapter",
      "Category": "ToolAdapter",
      "Description": "Fake email: create drafts; sending is gated and sandboxed (no transmission).",
      "Aliases": [],
      "Properties": {
        "Consumes": "act-draft-email,act-send-email",
        "SideEffect": "external-comm",
        "Capability": "email"
      }
    },
    {
      "Id": "tool-files",
      "Label": "file adapter",
      "Category": "ToolAdapter",
      "Description": "Fake filesystem: scan, classify, and (only on approval) delete sandboxed files.",
      "Aliases": [],
      "Properties": {
        "Consumes": "act-scan-downloads,act-classify-junk,act-delete-files",
        "SideEffect": "destructive",
        "Capability": "files"
      }
    },
    {
      "Id": "tool-repo",
      "Label": "repo adapter",
      "Category": "ToolAdapter",
      "Description": "Fake git repo: read, stage typed edits, run allow-listed commands, draft PRs. Nothing committed/pushed/executed.",
      "Aliases": [],
      "Properties": {
        "Consumes": "act-read-repo,act-modify-code,act-run-command,act-open-pull-request",
        "SideEffect": "command",
        "Capability": "repo"
      }
    },
    {
      "Id": "tool-data",
      "Label": "data adapter",
      "Category": "ToolAdapter",
      "Description": "Fake read-only analytics DB: compile typed query plans and execute reads. No mutations.",
      "Aliases": [],
      "Properties": {
        "Consumes": "act-build-query-plan,act-run-query",
        "SideEffect": "none",
        "Capability": "data"
      }
    }
  ],
