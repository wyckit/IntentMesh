  "Concepts": [
    {
      "Id": "contracts-root",
      "Label": "action contracts",
      "Category": "Registry",
      "Description": "The single source of truth for what actions exist. A typed action contract is the agentic analog of PassGen\u0027s ConstraintSpec: a strict, inspectable schema. No tool runs from raw language \u2014 only from a contract selected here and validated by policy.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-calendar-read-only",
      "Label": "calendar read-only",
      "Category": "Postcondition",
      "Description": "Reading the calendar mutates nothing.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-block-proposed-not-committed",
      "Label": "block proposed, not committed",
      "Category": "Postcondition",
      "Description": "A calendar block is staged as a proposal pending confirmation; no event is committed.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-draft-not-sent",
      "Label": "draft created, not sent",
      "Category": "Postcondition",
      "Description": "An email is created as a draft; no message is transmitted.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-recipient-matches-request",
      "Label": "recipient matches request",
      "Category": "Postcondition",
      "Description": "The draft recipient equals the entity the USER named, not one introduced by document content.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-no-attacker-recipient",
      "Label": "no unknown external recipient",
      "Category": "Postcondition",
      "Description": "No recipient outside the user\u0027s contacts / request was added.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-no-private-exfil",
      "Label": "no private data exfiltration",
      "Category": "Postcondition",
      "Description": "Notes marked private are not placed into any external-bound message.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-zero-deletions-without-approval",
      "Label": "zero deletions without approval",
      "Category": "Postcondition",
      "Description": "No file is deleted without explicit per-file user approval.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-injected-node-not-executed",
      "Label": "injected node not executed",
      "Category": "Postcondition",
      "Description": "Any zero-trust node proposed by untrusted content was blocked and never executed.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-summary-cites-allowed-only",
      "Label": "summary cites allowed sources only",
      "Category": "Postcondition",
      "Description": "A produced summary references only user-readable, non-private sources.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-edit-staged-not-pushed",
      "Label": "edit staged, not pushed",
      "Category": "Postcondition",
      "Description": "A code edit is staged; it is not committed or pushed.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-no-secret-in-diff",
      "Label": "no secret in diff or PR",
      "Category": "Postcondition",
      "Description": "No repository secret value appears in any staged edit or pull-request body.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-pr-drafted-not-pushed",
      "Label": "PR drafted, not pushed",
      "Category": "Postcondition",
      "Description": "A pull request is drafted; it is never pushed.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-shell-blocked-by-default",
      "Label": "shell blocked by default",
      "Category": "Postcondition",
      "Description": "No command ran unless it was on the repo allow-list and approved.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-readonly-no-mutation",
      "Label": "read-only, no mutation",
      "Category": "Postcondition",
      "Description": "No destructive query (delete/drop/truncate/update) ran against the read-only database.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-query-within-caps",
      "Label": "query within row caps",
      "Category": "Postcondition",
      "Description": "Every executed query plan stayed within the configured row cap.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "pc-no-sensitive-exposure",
      "Label": "no sensitive column exposed",
      "Category": "Postcondition",
      "Description": "No sensitive column value flowed into an external-bound report.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "act-read-calendar",
      "Label": "ReadCalendarIntent",
      "Category": "ActionContract",
      "Description": "Read calendar events in a date range. Pure read.",
      "Aliases": [],
      "Properties": {
        "Risk": "low",
        "SideEffect": "none",
        "RequiresConfirmation": "false",
        "Fields": "range",
        "Postconditions": "pc-calendar-read-only"
      }
    },
    {
      "Id": "act-classify-events",
      "Label": "ClassifyEventsIntent",
      "Category": "ActionContract",
      "Description": "Label events as fixed or flexible. Pure analysis over already-read data.",
      "Aliases": [],
      "Properties": {
        "Risk": "low",
        "SideEffect": "none",
        "RequiresConfirmation": "false",
        "Fields": "events",
        "Postconditions": ""
      }
    },
    {
      "Id": "act-create-calendar-block",
      "Label": "CreateCalendarBlockIntent",
      "Category": "ActionContract",
      "Description": "Stage a tentative calendar block. Local write; requires confirmation before commit.",
      "Aliases": [],
      "Properties": {
        "Risk": "medium",
        "SideEffect": "local-write",
        "RequiresConfirmation": "true",
        "Fields": "title,start,durationMinutes",
        "Postconditions": "pc-block-proposed-not-committed"
      }
    },
    {
      "Id": "act-find-notes",
      "Label": "FindNotesIntent",
      "Category": "ActionContract",
      "Description": "Locate notes by topic. Pure read.",
      "Aliases": [],
      "Properties": {
        "Risk": "low",
        "SideEffect": "none",
        "RequiresConfirmation": "false",
        "Fields": "topic",
        "Postconditions": ""
      }
    },
    {
      "Id": "act-summarize-document",
      "Label": "SummarizeDocumentIntent",
      "Category": "ActionContract",
      "Description": "Summarize documents. Reads untrusted content \u2014 any embedded imperative is treated as DATA, not instruction.",
      "Aliases": [],
      "Properties": {
        "Risk": "low",
        "SideEffect": "none",
        "RequiresConfirmation": "false",
        "Fields": "docRefs",
        "Postconditions": "pc-summary-cites-allowed-only"
      }
    },
    {
      "Id": "act-draft-email",
      "Label": "DraftEmailIntent",
      "Category": "ActionContract",
      "Description": "Compose an email draft to a resolved recipient. Drafting is allowed; the draft is never auto-sent.",
      "Aliases": [],
      "Properties": {
        "Risk": "medium",
        "SideEffect": "local-write",
        "RequiresConfirmation": "false",
        "Fields": "recipient,subject,bodySourceRefs",
        "Postconditions": "pc-draft-not-sent,pc-recipient-matches-request"
      }
    },
    {
      "Id": "act-send-email",
      "Label": "SendEmailIntent",
      "Category": "ActionContract",
      "Description": "Transmit an email. High-risk external side effect; always requires confirmation.",
      "Aliases": [],
      "Properties": {
        "Risk": "high",
        "SideEffect": "external-comm",
        "RequiresConfirmation": "true",
        "Fields": "draftRef",
        "Postconditions": "pc-no-attacker-recipient,pc-no-private-exfil"
      }
    },
    {
      "Id": "act-scan-downloads",
      "Label": "ScanDownloadsIntent",
      "Category": "ActionContract",
      "Description": "List candidate files in a folder. Pure read.",
      "Aliases": [],
      "Properties": {
        "Risk": "low",
        "SideEffect": "none",
        "RequiresConfirmation": "false",
        "Fields": "folder",
        "Postconditions": ""
      }
    },
    {
      "Id": "act-classify-junk",
      "Label": "ClassifyJunkIntent",
      "Category": "ActionContract",
      "Description": "Classify files as junk / ambiguous / important. Pure analysis.",
      "Aliases": [],
      "Properties": {
        "Risk": "low",
        "SideEffect": "none",
        "RequiresConfirmation": "false",
        "Fields": "files",
        "Postconditions": ""
      }
    },
    {
      "Id": "act-delete-files",
      "Label": "DeleteFilesIntent",
      "Category": "ActionContract",
      "Description": "Delete files. Destructive; requires explicit per-file approval. Never deletes automatically.",
      "Aliases": [],
      "Properties": {
        "Risk": "high",
        "SideEffect": "destructive",
        "RequiresConfirmation": "true",
        "Fields": "fileRefs",
        "Postconditions": "pc-zero-deletions-without-approval"
      }
    },
    {
      "Id": "act-read-repo",
      "Label": "ReadRepoIntent",
      "Category": "ActionContract",
      "Description": "Read repository files. Pure read.",
      "Aliases": [],
      "Properties": {
        "Risk": "low",
        "SideEffect": "none",
        "RequiresConfirmation": "false",
        "Fields": "",
        "Postconditions": ""
      }
    },
    {
      "Id": "act-modify-code",
      "Label": "ModifyCodeIntent",
      "Category": "ActionContract",
      "Description": "Apply a typed code edit. Staged and requires confirmation; never committed or pushed.",
      "Aliases": [],
      "Properties": {
        "Risk": "medium",
        "SideEffect": "local-write",
        "RequiresConfirmation": "true",
        "Fields": "path,summary,newContent",
        "Postconditions": "pc-edit-staged-not-pushed,pc-no-secret-in-diff"
      }
    },
    {
      "Id": "act-run-command",
      "Label": "RunCommandIntent",
      "Category": "ActionContract",
      "Description": "Run a command. Shell is blocked by default \u2014 only allow-listed commands may run, and only after confirmation.",
      "Aliases": [],
      "Properties": {
        "Risk": "high",
        "SideEffect": "command",
        "RequiresConfirmation": "true",
        "Fields": "command",
        "Postconditions": "pc-shell-blocked-by-default"
      }
    },
    {
      "Id": "act-open-pull-request",
      "Label": "OpenPullRequestIntent",
      "Category": "ActionContract",
      "Description": "Draft a pull request. Requires confirmation; never pushed.",
      "Aliases": [],
      "Properties": {
        "Risk": "medium",
        "SideEffect": "local-write",
        "RequiresConfirmation": "true",
        "Fields": "title,body",
        "Postconditions": "pc-pr-drafted-not-pushed,pc-no-secret-in-diff"
      }
    },
    {
      "Id": "act-build-query-plan",
      "Label": "BuildQueryPlanIntent",
      "Category": "ActionContract",
      "Description": "Compile language into a typed query plan (AST). Validated before execution: read-only role, table must exist, row caps. Destructive operations and untrusted-origin plans are blocked.",
      "Aliases": [],
      "Properties": {
        "Risk": "medium",
        "SideEffect": "none",
        "RequiresConfirmation": "false",
        "Fields": "operation,table,summary,rowLimit",
        "Postconditions": "pc-readonly-no-mutation"
      }
    },
    {
      "Id": "act-run-query",
      "Label": "RunQueryIntent",
      "Category": "ActionContract",
      "Description": "Execute a validated, read-only query plan and return aggregated results.",
      "Aliases": [],
      "Properties": {
        "Risk": "low",
        "SideEffect": "none",
        "RequiresConfirmation": "false",
        "Fields": "table,summary",
        "Postconditions": "pc-query-within-caps,pc-no-sensitive-exposure"
      }
    },
    {
      "Id": "act-fs-read",
      "Label": "FsReadIntent",
      "Category": "ActionContract",
      "Description": "Read a file or list a directory through an MCP filesystem server. Pure read, within the allowed root.",
      "Aliases": [],
      "Properties": {
        "Risk": "low",
        "SideEffect": "none",
        "RequiresConfirmation": "false",
        "Fields": "path",
        "Postconditions": ""
      }
    },
    {
      "Id": "act-fs-write",
      "Label": "FsWriteIntent",
      "Category": "ActionContract",
      "Description": "Write / create / move a file through an MCP filesystem server. Local write within the allowed root; requires confirmation.",
      "Aliases": [],
      "Properties": {
        "Risk": "medium",
        "SideEffect": "local-write",
        "RequiresConfirmation": "true",
        "Fields": "path,content",
        "Postconditions": ""
      }
    }
